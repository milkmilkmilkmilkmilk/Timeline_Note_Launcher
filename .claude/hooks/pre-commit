#!/usr/bin/env bash
# Pre-commit hook: Run ESLint before allowing commit
# Installed from .claude/hooks/pre-commit
# To bypass: git commit --no-verify

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$SCRIPT_DIR"

echo "Running pre-commit lint check..."
echo ""

# Use npm.sh wrapper to ensure Node.js is in PATH
if ! ./npm.sh run lint; then
    echo ""
    echo "❌ Lint check failed!"
    echo "Fix errors above or use 'git commit --no-verify' to skip this check."
    echo ""
    exit 1
fi

echo ""
echo "✓ Lint check passed"
exit 0
